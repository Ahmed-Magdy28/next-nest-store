{
  "name": "@repo/database",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate": "dotenv -e ../../.env -- prisma generate --schema=./prisma/schema.prisma",
    "migrate": "dotenv -e ../../.env -- prisma migrate dev --schema=./prisma/schema.prisma",
    "migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy --schema=./prisma/schema.prisma",
    "studio": "dotenv -e ../../.env -- prisma studio --schema=./prisma/schema.prisma"
  },
  "dependencies": {
    "@nestjs/common": "^11.x",
    "@nestjs/core": "^11.x",
    "@prisma/client": "^6.19.3"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^26.1.0",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.19.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.2"
  }
}