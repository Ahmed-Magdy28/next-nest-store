{
  "name": "next-nest-store",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:frontend": "turbo run dev --filter=web",
    "dev:backend": "turbo run dev --filter=backend",
    "db:generate": "pnpm --filter @repo/database generate",
    "db:migrate": "pnpm --filter @repo/database migrate",
    "db:studio": "pnpm --filter @repo/database studio",
    "db:push": "pnpm --filter @repo/database push",
    "db:reset": "pnpm --filter @repo/database reset",
    "db:seed": "pnpm --filter @repo/database seed",
    "db:format": "pnpm --filter @repo/database format",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.10.2",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  }
}